{
  "id": null,
  "uid": "recipe-platform-overview",
  "title": "Recipe Delivery Platform - Overview",
  "tags": ["spring-boot", "microservices"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(jvm_memory_used_bytes, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$service\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=~\"$service\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "P99 Response Time (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\"$service\"}[1m])) by (job, le)) * 1000",
          "legendFormat": "{{job}} p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=~\"$service\"} / 1024 / 1024",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"$service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"$service\"} * 100",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Services Up",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(up{job=~\"$service\"} == 1)",
          "legendFormat": "Services Healthy"
        }
      ]
    },
    {
      "id": 8,
      "title": "Kafka Consumer Lag (order-service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag{job=\"order-service\"}",
          "legendFormat": "{{topic}} - {{partition}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "GC Pause Time (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"$service\"}[1m]) * 1000",
          "legendFormat": "{{job}} {{action}}"
        }
      ]
    }
  ]
}
